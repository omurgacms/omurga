{
  "slug": "omurga-sabit",
  "id": "omurga-sabit",
  "name": "Omurga Sabit",
  "version": "1.0.3.7-beta",
  "description": "Omurga CMS için sade, klasik PHP tabanlı varsayılan tema.",
  "author": "Omurga CMS",
  "template_engine": "php",
  "system_theme": true,
  "supports": [
    "menus",
    "comments",
    "responsive"
  ],
  "menu_locations": {
    "main": "Ana Menü",
    "mobile": "Mobil Menü",
    "footer": "Footer Menü",
    "top": "Üst Menü"
  },
  "regions": {
    "header": "Üst Alan",
    "home_top": "Ana Sayfa Üstü",
    "home_main": "Ana İçerik",
    "sidebar": "Yan Alan",
    "post_inside": "Yazı Detay İçi",
    "footer": "Alt Alan"
  },
  "settings": {
    "logo": {
      "type": "image",
      "label": "Logo",
      "default": ""
    },
    "primary_color": {
      "type": "color",
      "label": "Ana Renk",
      "default": "#f97316"
    },
    "show_author": {
      "type": "checkbox",
      "label": "Yazıda yazarı göster",
      "default": "1"
    },
    "layout_width": {
      "type": "select",
      "label": "İçerik genişliği",
      "default": "normal",
      "options": {
        "normal": "Normal",
        "wide": "Geniş"
      }
    }
  },
  "hooks": [
    "omurga_theme_loaded",
    "omurga_before_post_render",
    "omurga_before_omg_render"
  ]
}