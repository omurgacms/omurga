<article class="card">
  @if(post.image)
    <a href="{{ post.url }}"><img src="{{ post.image }}" alt="{{ post.title }}"></a>
  @endif
  <div class="card-body">
    <small>{{ post.category }}</small>
    <h2><a href="{{ post.url }}">{{ post.title }}</a></h2>
    <p>{{ post.excerpt }}</p>
  </div>
</article>
