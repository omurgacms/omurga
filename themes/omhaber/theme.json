{
  "name": "OmHaber",
  "slug": "omhaber",
  "version": "1.1.3",
  "author": "Omurga",
  "type": [
    "news"
  ],
  "description": "Omurga için bağımsız PHP tabanlı, kendi blokları olan modern profesyonel haber teması. Haber V1 ile bağlantısı yoktur.",
  "screenshot": "screenshot.png",
  "regions": {
    "header": "OmHaber Üst Alan",
    "home_top": "OmHaber Ana Sayfa Üstü",
    "home_main": "OmHaber Ana İçerik",
    "sidebar": "OmHaber Yan Alan",
    "post_inside": "Yazı Detay İçi",
    "footer": "OmHaber Footer",
    "mobile_bottom": "Mobil Alt Menü"
  },
  "supports": [
    "menus",
    "responsive",
    "layout",
    "theme-blocks",
    "theme-settings",
    "news-layout"
  ],
  "templates": {
    "page": {
      "default": {
        "name": "OmHaber Sayfa",
        "file": "page.php",
        "description": "OmHaber standart sayfa."
      }
    },
    "single": {
      "default": {
        "name": "OmHaber Haber Detay",
        "file": "single.php",
        "description": "OmHaber haber detay görünümü."
      }
    }
  },
  "settings": {
    "primary_color": {
      "type": "color",
      "label": "Ana Vurgu Rengi",
      "default": "#f97316"
    },
    "dark_color": {
      "type": "color",
      "label": "Header / Footer Koyu Renk",
      "default": "#0f172a"
    },
    "logo_text": {
      "type": "text",
      "label": "Logo Metni",
      "default": "OmHaber"
    },
    "site_width": {
      "type": "select",
      "label": "Site Genişliği",
      "default": "wide",
      "options": {
        "wide": "Geniş",
        "full": "Tam Ekran",
        "boxed": "Kutulu"
      }
    },
    "topbar_text": {
      "type": "text",
      "label": "Üst Bar Sol Yazı",
      "default": "14 Mayıs 2025 Çarşamba | İstanbul 18°C"
    },
    "live_url": {
      "type": "url",
      "label": "Canlı Yayın Linki",
      "default": "#"
    },
    "facebook_url": {
      "type": "url",
      "label": "Facebook",
      "default": "#"
